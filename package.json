{
  "name": "stack-mentor-ai",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@10.6.5",
  "scripts": {
    "dev": "pnpm --parallel --filter @stack-mentor/web --filter @stack-mentor/api dev",
